{
  "name": "delivery_management_system",
  "version": "1.0.0",
  "dependencies": {
    "@cap-js/hana": "^2",
    "@sap/cds": "^9",
    "@sap/xssec": "^4"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^2",
    "@sap/cds-dk": "^9",
    "cds-plugin-ui5": "^0.13.0"
  },
  "scripts": {
    "start": "cds-serve",
    "watch-customer": "cds watch --open customer/index.html?sap-ui-xx-viewCache=false --livereload false",
    "watch-drivers": "cds watch --open drivers/index.html?sap-ui-xx-viewCache=false --livereload false"
  },
  "private": true,
  "workspaces": [
    "app/*"
  ],
  "sapux": [
    "app/customer",
    "app/drivers"
  ],
  "cds": {
    "requires": {
      "auth": {
        "kind": "mocked",
        "users": {
          "a": {
            "password": "",
            "roles": [
              "admin"
            ]
          },
          "cust": {
            "password": "",
            "roles": [
              "customer"
            ]
          },
          "driv": {
            "password": "",
            "roles": [
              "driver"
            ]
          }
        }
      },
      "[production]": {
        "db": "hana",
        "auth": {
          "kind": "xsuaa"
        }
      },
      "destinations": true,
      "html5-repo": true,
      "workzone": true
    }
  }
}
